# ─────────────────────────────────────────────────────────────
#  GrabDiscount — Template variables d'environnement
#  Copie en .env et remplis les valeurs. NE JAMAIS commit .env
# ─────────────────────────────────────────────────────────────

# ─── Telegram Bot (obligatoire) ──────────────────────────────
# Token fourni par @BotFather
BOT_TOKEN=
# Ton chat ID Telegram personnel (récupérable via @userinfobot)
ADMIN_CHAT_ID=
# ID du canal privé (format -100XXXXXXXXXX)
CHANNEL_ID=

# ─── Dashboard admin (obligatoire) ───────────────────────────
# Mot de passe admin (change en prod, ne pas partager)
DASHBOARD_PASSWORD=
# Mot de passe espace employé (facultatif — défaut: même que admin)
EMPLOYEE_PASSWORD=
# Secret Flask session — 32+ chars aléatoires
# Génère avec: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
DASHBOARD_SECRET=
# Port HTTP (défaut 5001)
DASHBOARD_PORT=5001

# ─── Données (facultatif) ────────────────────────────────────
# Dossier contenant accounts.json / orders.json / messages.json / subscribers.json
# Laisser vide = dossier courant. En prod VPS: /data
DATA_DIR=

# ─── SMSPool (facultatif — pour signup Grab) ─────────────────
# https://smspool.net → Dashboard → API
SMSPOOL_KEY=

# ─── Alternatives SMS (facultatif) ───────────────────────────
FIVESIM_KEY=
SMSACTIVATE_KEY=
HEROSMS_KEY=

# ─── iCloud IMAP (facultatif — OTP email Grab) ───────────────
# appleid.apple.com → Sécurité → Mots de passe spécifiques apps
ICLOUD_EMAIL=
ICLOUD_APPPASS=

# ─── Git (facultatif — push restaurants.json auto) ───────────
GIT_TOKEN=

# ─── Sentry (facultatif — monitoring erreurs) ────────────────
# https://sentry.io → Project → Settings → Client Keys (DSN)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
